model Education {
  id             Int           @id @default(autoincrement())

  type           EducationType
  year           String
  dateRange      String
  degree         String
  institute      String
  location       String
  description    String
  tags           String[]
  creadentialUrl String?
  isPublished Boolean @default(true)
  order          Int           @default(0)

  updatedAt DateTime @updatedAt
}
